# Server Configuration
PORT=5000
NODE_ENV=development

# Database (Atlas)
# Use split variables so the app can safely URL-encode credentials
# Comment out/remove MONGODB_URI to avoid conflicts
# MONGODB_URI=
MONGODB_USERNAME=sgp_app
MONGODB_PASSWORD=654himachal
MONGODB_CLUSTER=cluster0.qbkibzp.mongodb.net
MONGODB_DBNAME=sports_equipment

# Tokens used by user.models.js (set non-default in real deployments)
ACCESS_TOKEN_SECRET=dev-secret
ACCESS_TOKEN_EXPIRY=7d

# JWT
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# Email (Notifications) - Optional
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_password

# File Upload
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100
